# ═══════════════════════════════════════════════════════
# NEXTWAVES BOT — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas .env a GitHub
# ═══════════════════════════════════════════════════════

# Binance API — usa claves con permisos SOLO de trading spot
# NUNCA actives permisos de retiro
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# Telegram Bot
# Crea un bot en @BotFather y obtén el token
TELEGRAM_TOKEN=tu_telegram_token_aqui
# Tu Telegram user ID (puedes obtenerlo con @userinfobot)
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Modo del bot: live | shadow | paper
BOT_MODE=shadow

# Estilo de trading — autoajusta timeframe y parámetros
# scalper    → 15m / HTF 1h   (operaciones rápidas, ~cada 15 min)
# day_trader → 1h  / HTF 4h   (intradía)
# swing      → 4h  / HTF 1d   (posiciones de días, default)
TRADING_STYLE=swing

# Par de trading
SYMBOL=BTC/USDT

# Capital máximo en riesgo (USDT) — modos paper/live
MAX_CAPITAL_USDT=1000.0

# Capital virtual para shadow trading (no afecta dinero real)
SHADOW_CAPITAL=10000.0

# Porcentaje del capital por operación (0.25 = 25%)
POSITION_SIZE_PCT=0.25

# Dashboard Streamlit (opcional)
# Obligatorio si usas Tailscale (PC + móvil):
DASHBOARD_PASSWORD=
DASHBOARD_PORT=8501
